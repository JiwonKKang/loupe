{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Loupe",
  "version": "0.2.0",
  "identifier": "com.jiwon.loupe",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Loupe",
        "width": 1280,
        "height": 860,
        "minWidth": 940,
        "minHeight": 640,
        "center": true,
        "resizable": true,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "trafficLightPosition": { "x": 19, "y": 28 }
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "deep-link": {
      "desktop": {
        "schemes": ["loupe"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": ["dmg", "app"],
    "resources": ["loupe"],
    "category": "DeveloperTool",
    "copyright": "© 2026 강지원",
    "shortDescription": "Human-first code review",
    "longDescription": "Loupe reorders a PR diff into data-flow order and walks you through it one symbol-card at a time, with AI clustering, labels, and inline codebase-aware Q&A.",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "signingIdentity": "-",
      "minimumSystemVersion": "11.0"
    }
  }
}
